---
import heroImg from '../assets/hassan-pasha-nEbMedmVwgw-unsplash.jpg'
import Contact from '../components/Contact.astro'
import Hero from '../components/Hero.astro'
import Offerings from '../components/Offerings.astro'
import Reviews from '../components/Reviews.astro'
import Story from '../components/Story.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout title="Home">
  <Hero
    headlinePrefix="Enter the"
    headlineAccent="Castle Grounds"
    description="Tournaments, festivals, and fellowship hath filled these grounds for fourscore years. Come see what awaiteth beyond the gate."
    primaryCta={{ label: "See What's On", href: "#" }}
    secondaryCta={{ label: "Our Story", href: "#story" }}
    image={{ src: heroImg, alt: "Chess board" }}
  />
  <Offerings />
  <Story />
  <Reviews />
  <Contact />
</Layout>
