---
import { Crown, Swords, Trophy } from '@lucide/astro'

const offerings = [
  {
    icon: Crown,
    iconBg: 'bg-warning/15',
    iconColor: 'text-warning',
    title: 'The Lists',
    description:
      'Witness the thunder of horse and lance upon the field. Our tourneys doth draw knights of great renown, and no two passes art ever alike.',
  },
  {
    icon: Swords,
    iconBg: 'bg-error/15',
    iconColor: 'text-error',
    title: 'The Grounds',
    description:
      'Beyond the gates lie festivals of every season. Minstrels, merchants, and men-at-arms gather here as they have done for fourscore years and more.',
  },
  {
    icon: Trophy,
    iconBg: 'bg-primary/15',
    iconColor: 'text-primary',
    title: 'The Tavern',
    description:
      'When the day hath spent itself upon the field, come hither and rest thy bones. Good company awaiteth within, as it ever doth.',
  },
]
---

<section class="py-20 bg-base-200">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl lg:text-5xl font-bold mb-4">Adventure Awaits</h2>
      <p class="text-base-content/60 max-w-xl mx-auto">
        There is much to be found within these walls and upon these grounds. Come with purpose or
        come without. Thou shalt not leave wanting.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        offerings.map(({ icon: Icon, iconBg, iconColor, title, description }) => (
          <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
              <div class={`w-14 h-14 rounded-full ${iconBg} flex items-center justify-center mb-2`}>
                <Icon class={`${iconColor} size-7`} />
              </div>
              <h3 class="card-title">{title}</h3>
              <p class="text-base-content/60 text-sm leading-relaxed">{description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
