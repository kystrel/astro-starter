---
import { brandingConfig } from '../config/branding.config'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  article?: {
    publishedTime: Date
    modifiedTime?: Date
    authors?: string[]
    tags?: string[]
  }
}

const {
  title,
  description = brandingConfig.site.description,
  ogImage = brandingConfig.site.ogImage,
  article,
} = Astro.props

const pageTitle = title
  ? `${title} | ${brandingConfig.site.name}`
  : brandingConfig.site.name
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).href : undefined

// ── LocalBusiness JSON-LD ────────────────────────────────────────────────────
const { business, site } = brandingConfig
let localBusinessJson: string | undefined

if (business) {
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': business.schemaType ?? 'LocalBusiness',
    name: site.name,
    url: site.siteUrl,
    ...(business.email && { email: business.email }),
    ...(business.phone && { telephone: business.phone }),
    ...(business.address && {
      address: {
        '@type': 'PostalAddress',
        streetAddress: business.address,
      },
    }),
    ...(business.hours && { openingHours: business.hours }),
    ...(business.coordinates && {
      geo: {
        '@type': 'GeoCoordinates',
        latitude: business.coordinates.lat,
        longitude: business.coordinates.lng,
      },
    }),
  }
  // Escape </script> to prevent early tag termination.
  localBusinessJson = JSON.stringify(schema).replace(
    /<\/script>/gi,
    '<\\/script>',
  )
}
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}sitemap-index.xml`} />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={brandingConfig.site.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
{article && <meta property="article:published_time" content={article.publishedTime.toISOString()} />}
{article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />}
{article?.authors?.map((author) => <meta property="article:author" content={author} />)}
{article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
<meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
{localBusinessJson && <script is:inline type="application/ld+json" set:html={localBusinessJson} />}
