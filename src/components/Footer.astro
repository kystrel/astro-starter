---
import { ChessKnight } from '@lucide/astro'
import { siteConfig } from '../config/site'
---

<footer class="footer sm:footer-horizontal bg-base-200 text-base-content p-10">
  <aside>
    <ChessKnight />
    <p class="text-lg font-bold">{siteConfig.name}</p>
    <p class="text-base-content/60">{siteConfig.tagline}</p>
  </aside>
  {siteConfig.footerGroups.map(({ title, links }) => (
    <nav>
      <h6 class="footer-title">{title}</h6>
      {links.map(({ label, href }) => (
        <a href={href} class="link link-hover">{label}</a>
      ))}
    </nav>
  ))}
  <nav>
    <h6 class="footer-title">Connect</h6>
    {siteConfig.social.map(({ platform, href }) => (
      <a href={href} class="link link-hover">{platform}</a>
    ))}
  </nav>
</footer>
<div class="bg-base-200 w-full">
<hr class="border-base-300 mx-10" />
</div>
<footer class="footer footer-center bg-base-200 text-base-content p-4">
  <p>© {new Date().getFullYear()} {siteConfig.copyright}. All rights reserved.</p>
</footer>
