---
import { siteConfig } from '../config/site'

interface BreadcrumbItem {
  name: string
  href: string
}

interface Props {
  breadcrumbs?: BreadcrumbItem[]
  article?: {
    title: string
    description: string
    publishedTime: Date
    modifiedTime?: Date
    authors?: string[]
    image?: string
  }
}

const { breadcrumbs, article } = Astro.props

const { business, name, siteUrl } = siteConfig
const pageUrl = new URL(Astro.url.pathname, Astro.site).href

const schemas: object[] = []

if (business) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name,
    url: siteUrl,
    telephone: business.phone,
    email: business.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: business.address,
    },
    openingHours: business.hours,
    ...(business.coordinates && {
      geo: {
        '@type': 'GeoCoordinates',
        latitude: business.coordinates.lat,
        longitude: business.coordinates.lng,
      },
    }),
  })
}

const crumbs = breadcrumbs ?? []
const isHomePage =
  Astro.url.pathname === '/' ||
  Astro.url.pathname === `${import.meta.env.BASE_URL}/` ||
  Astro.url.pathname === import.meta.env.BASE_URL

if (!isHomePage && crumbs.length === 0) {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '')
  const segments = Astro.url.pathname
    .replace(base, '')
    .split('/')
    .filter(Boolean)

  let builtPath = base
  const autoCrumbs: BreadcrumbItem[] = [{ name: 'Home', href: base || '/' }]

  for (const segment of segments) {
    builtPath += `/${segment}`
    autoCrumbs.push({
      name: segment
        .split('-')
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
        .join(' '),
      href: builtPath,
    })
  }

  if (autoCrumbs.length > 1) {
    schemas.push({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: autoCrumbs.map((crumb, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: crumb.name,
        item: new URL(crumb.href, Astro.site).href,
      })),
    })
  }
} else if (crumbs.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: crumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.href, Astro.site).href,
    })),
  })
}

if (article) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: article.title,
    description: article.description,
    url: pageUrl,
    datePublished: article.publishedTime.toISOString(),
    ...(article.modifiedTime && {
      dateModified: article.modifiedTime.toISOString(),
    }),
    ...(article.authors?.length && {
      author: article.authors.map((author) => ({
        '@type': 'Person',
        name: author,
      })),
    }),
    ...(article.image && {
      image: new URL(article.image, Astro.site).href,
    }),
    publisher: {
      '@type': 'Organization',
      name,
      url: siteUrl,
    },
  })
}
---

{
  schemas.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
