---
import { Moon, Sun } from '@lucide/astro'
---

<label class="swap swap-rotate btn btn-ghost btn-circle" aria-label="Toggle theme">
  <input id="theme-toggle" type="checkbox" />
  <Sun class="swap-off size-5" />
  <Moon class="swap-on size-5" />
</label>

<script>
  const STORAGE_KEY = 'theme'

  function getThemes(): { light: string; dark: string } {
    const el = document.documentElement
    return {
      light: el.dataset.themeLight ?? 'light',
      dark: el.dataset.themeDark ?? 'dark',
    }
  }

  function applyTheme(isDark: boolean) {
    const { light, dark } = getThemes()
    document.documentElement.setAttribute('data-theme', isDark ? dark : light)
    localStorage.setItem(STORAGE_KEY, isDark ? 'dark' : 'light')
    const toggle = document.getElementById('theme-toggle') as HTMLInputElement | null
    if (toggle) toggle.checked = isDark
  }

  const saved = localStorage.getItem(STORAGE_KEY)
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
  applyTheme(saved ? saved === 'dark' : prefersDark)

  document.getElementById('theme-toggle')?.addEventListener('change', (e) => {
    applyTheme((e.target as HTMLInputElement).checked)
  })
</script>
