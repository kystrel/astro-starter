---
import type { ComponentProps } from 'astro/types'
import '../styles/global.css'
import BaseHead from '../components/BaseHead.astro'
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'
import { siteConfig } from '../config/site'

type Props = ComponentProps<typeof BaseHead>

const { title, description, ogImage, article } = Astro.props
const { light: lightTheme, dark: darkTheme } = siteConfig.theme
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline define:vars={{ lightTheme, darkTheme }}>
      ;(function () {
        var stored = localStorage.getItem('theme')
        var mode = stored === 'dark' || stored === 'light'
          ? stored
          : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        document.documentElement.setAttribute('data-theme', mode === 'dark' ? darkTheme : lightTheme)
      })()
    </script>
		<BaseHead title={title} description={description} ogImage={ogImage} article={article} />
		<slot name="head" />
	</head>
	<body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
		  <slot />
    </main>
    <Footer />
	</body>
</html>
